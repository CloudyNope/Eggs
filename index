<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-overline">A Study in Natural Form</div>
    <h1>The<br><em>Eouf</em><br>Examined</h1>
    <p class="hero-desc">One of evolution's most enduring structures — a self-contained life support system that has sustained complex organisms for over 300 million years.</p>
    <div class="hero-stats">
