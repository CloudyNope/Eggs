<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Eouf — A Study in Nature's Perfect Form</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:          #1a0a2e;
      --purple-rich:  #2d0a5e;
      --purple-mid:   #5b21b6;
      --purple-soft:  #8b5cf6;
      --purple-mist:  #ede9fe;
      --purple-frost: #f5f3ff;
      --white:        #ffffff;
      --off-white:    #faf9fc;
      --rule:         #e4dff4;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--white);
      color: var(--ink);
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--rule);
      padding: 0 56px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-wordmark {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: 6px;
      text-transform: uppercase;
      color: var(--ink);
    }
    .nav-wordmark span { color: var(--purple-mid); }
    nav ul { list-style: none; display: flex; gap: 36px; }
    nav ul a {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      opacity: 0.55;
      transition: opacity 0.2s;
    }
    nav ul a:hover { opacity: 1; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      padding-top: 64px;
      background: var(--purple-rich);
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
      overflow: hidden;
    }
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(139,92,246,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 56px;
      z-index: 2;
    }
    .hero-overline {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--purple-soft);
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .hero-overline::before {
      content: '';
      display: block;
      width: 32px;
      height: 1px;
      background: var(--purple-soft);
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(52px, 6vw, 88px);
      font-weight: 300;
      color: var(--white);
      line-height: 1.05;
      margin-bottom: 32px;
      letter-spacing: -1px;
    }
    .hero h1 em {
      font-style: italic;
      color: var(--purple-soft);
    }
    .hero-desc {
      font-size: 14px;
      font-weight: 300;
      color: rgba(255,255,255,0.55);
      line-height: 1.9;
      max-width: 380px;
      margin-bottom: 48px;
    }
    .hero-stats {
      display: flex;
      gap: 40px;
    }
    .hero-stat { border-top: 1px solid rgba(255,255,255,0.15); padding-top: 16px; }
    .hero-stat .hs-val {
      font-family: 'Cormorant Garamond', serif;
      font-size: 32px;
      font-weight: 300;
      color: var(--white);
      line-height: 1;
      margin-bottom: 6px;
    }
    .hero-stat .hs-label {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }
    .hero-right {
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      position: relative;
    }
    .hero-eouf-graphic {
      width: 280px;
      height: 340px;
      background: linear-gradient(145deg, rgba(139,92,246,0.25) 0%, rgba(255,255,255,0.06) 100%);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 100px;
      box-shadow: 0 40px 80px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
    }

    /* ── SHARED ── */
    .eyebrow {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--purple-mid);
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }
    .eyebrow::before { content: ''; display: block; width: 28px; height: 1px; background: var(--purple-mid); }

    h2.serif {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -0.5px;
      color: var(--ink);
      margin-bottom: 20px;
    }
    h2.serif em { font-style: italic; color: var(--purple-mid); }
    h2.serif.light { color: var(--white); }
    h2.serif.light em { color: var(--purple-soft); }

    .body-text {
      font-size: 14px;
      font-weight: 300;
      color: #4a3560;
      line-height: 1.9;
      max-width: 600px;
    }
    .body-text.light { color: rgba(255,255,255,0.55); }

    .rule { border: none; border-top: 1px solid var(--rule); margin: 0; }

    /* ── WHAT IS ── */
    .what-section { padding: 120px 56px; max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: start; }
    .what-cards { display: flex; flex-direction: column; gap: 0; }
    .what-card {
      padding: 28px 0;
      border-bottom: 1px solid var(--rule);
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 20px;
      align-items: start;
    }
    .what-card:first-child { border-top: 1px solid var(--rule); }
    .wc-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--purple-mid);
      opacity: 0.5;
      padding-top: 2px;
    }
    .wc-title { font-size: 12px; font-weight: 600; letter-spacing: 1px; color: var(--ink); margin-bottom: 8px; text-transform: uppercase; }
    .wc-text { font-size: 13px; font-weight: 300; color: #4a3560; line-height: 1.85; }

    /* ── ANATOMY ── */
    .anatomy-outer { background: var(--purple-rich); padding: 120px 0; }
    .anatomy-inner { max-width: 1200px; margin: 0 auto; padding: 0 56px; }
    .anatomy-header { margin-bottom: 72px; }
    .anatomy-parts {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 2px;
    }
    .a-part {
      background: var(--purple-rich);
      padding: 36px 28px;
      transition: background 0.25s;
    }
    .a-part:hover { background: rgba(255,255,255,0.05); }
    .a-part-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 11px;
      color: var(--purple-soft);
      opacity: 0.6;
      letter-spacing: 2px;
      margin-bottom: 20px;
      display: block;
    }
    .a-part h4 {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 12px;
    }
    .a-part p { font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.45); line-height: 1.85; }

    /* ── TYPES ── */
    .types-section { padding: 120px 56px; max-width: 1200px; margin: 0 auto; }
    .types-header { margin-bottom: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; }
    .types-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    .type-card {
      background: var(--white);
      padding: 40px 32px;
      transition: background 0.2s;
    }
    .type-card:hover { background: var(--purple-frost); }
    .tc-icon { font-size: 28px; margin-bottom: 20px; display: block; }
    .tc-name { font-size: 10px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: var(--purple-mid); margin-bottom: 10px; }
    .tc-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 14px;
      line-height: 1.2;
    }
    .tc-text { font-size: 12px; font-weight: 300; color: #4a3560; line-height: 1.85; }

    /* ── DEVELOPMENT ── */
    .dev-section { background: var(--off-white); padding: 120px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
    .dev-inner { max-width: 1200px; margin: 0 auto; padding: 0 56px; }
    .dev-header { margin-bottom: 72px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; }
    .stages-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 0;
      border: 1px solid var(--rule);
      background: var(--rule);
      margin-bottom: 80px;
    }
    .stage {
      background: var(--white);
      padding: 32px 20px;
      position: relative;
    }
    .stage::after {
      content: '';
      position: absolute;
      top: 32px; right: 0;
      width: 1px; height: 24px;
      background: var(--rule);
    }
    .stage:last-child::after { display: none; }
    .st-day { font-size: 9px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--purple-mid); opacity: 0.7; margin-bottom: 16px; display: block; }
    .st-icon { font-size: 24px; display: block; margin-bottom: 14px; }
    .st-title { font-size: 11px; font-weight: 600; color: var(--ink); letter-spacing: 0.5px; margin-bottom: 8px; text-transform: uppercase; }
    .st-text { font-size: 11px; font-weight: 300; color: #4a3560; line-height: 1.75; }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    .stat-cell {
      background: var(--white);
      padding: 40px 32px;
    }
    .stat-label { font-size: 9px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--purple-mid); opacity: 0.7; margin-bottom: 12px; display: block; }
    .stat-val {
      font-family: 'Cormorant Garamond', serif;
      font-size: 44px;
      font-weight: 300;
      color: var(--ink);
      line-height: 1;
      margin-bottom: 10px;
    }
    .stat-desc { font-size: 12px; font-weight: 300; color: #4a3560; line-height: 1.75; }

    /* ── INCUBATION ── */
    .incub-section { padding: 120px 56px; max-width: 1200px; margin: 0 auto; }
    .incub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--rule); border: 1px solid var(--rule); margin-top: 64px; }
    .incub-cell { background: var(--white); padding: 48px 40px; }
    .incub-cell h3 { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 400; color: var(--ink); margin-bottom: 24px; }
    .incub-cell ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .incub-cell li { font-size: 13px; font-weight: 300; color: #4a3560; line-height: 1.7; padding-left: 20px; position: relative; }
    .incub-cell li::before { content: '—'; position: absolute; left: 0; color: var(--purple-mid); opacity: 0.5; }

    /* ── CHAOS THEORY ── */
    .chaos-outer { background: var(--purple-rich); padding: 120px 0; }
    .chaos-inner-wrap { max-width: 1200px; margin: 0 auto; padding: 0 56px; }
    .chaos-header { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end; margin-bottom: 72px; }
    .chaos-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
      margin-bottom: 32px;
    }
    .chaos-cell {
      background: var(--purple-rich);
      padding: 40px 36px;
      transition: background 0.2s;
    }
    .chaos-cell:hover { background: rgba(255,255,255,0.04); }
    .chaos-cell h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      color: var(--white);
      margin-bottom: 14px;
      line-height: 1.25;
    }
    .chaos-cell p { font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.45); line-height: 1.85; }
    .chaos-connection {
      border: 1px solid rgba(255,255,255,0.12);
      padding: 48px;
    }
    .chaos-connection .cc-label { font-size: 9px; font-weight: 600; letter-spacing: 4px; text-transform: uppercase; color: var(--purple-soft); opacity: 0.7; margin-bottom: 20px; display: block; }
    .chaos-connection h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 30px;
      font-weight: 300;
      color: var(--white);
      margin-bottom: 24px;
      line-height: 1.2;
    }
    .chaos-connection p { font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.5); line-height: 1.9; margin-bottom: 18px; }
    .chaos-connection p:last-child { margin-bottom: 0; }
    .chaos-connection p strong { color: rgba(255,255,255,0.85); font-weight: 500; }

    /* ── FUN FACTS ── */
    .facts-section { padding: 120px 56px; max-width: 1200px; margin: 0 auto; }
    .facts-header { margin-bottom: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; }
    .facts-list { display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--rule); }
    .fact-row {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 36px;
      align-items: start;
      padding: 36px 0;
      border-bottom: 1px solid var(--rule);
      transition: background 0.2s;
    }
    .fact-row:hover { background: var(--purple-frost); margin: 0 -24px; padding: 36px 24px; }
    .fact-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--purple-mid);
      opacity: 0.4;
      padding-top: 3px;
      letter-spacing: 2px;
    }
    .fact-content h4 { font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--ink); margin-bottom: 10px; }
    .fact-content p { font-size: 13px; font-weight: 300; color: #4a3560; line-height: 1.85; }
    .fact-content p strong { color: var(--purple-mid); font-weight: 600; }

    /* ── FOOTER ── */
    footer {
      background: var(--ink);
      padding: 48px 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-mark {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 300;
      letter-spacing: 6px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
    .footer-text { font-size: 11px; font-weight: 300; color: rgba(255,255,255,0.2); letter-spacing: 1px; }

    /* ── RESPONSIVE ── */
    @media (max-width: 960px) {
      nav { padding: 0 24px; }
      nav ul { display: none; }
      .hero { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .hero-left { padding: 60px 28px; }
      .what-section, .types-header, .dev-header, .chaos-header, .facts-header { grid-template-columns: 1fr; gap: 40px; padding: 80px 28px; }
      .types-section, .incub-section, .facts-section { padding: 80px 28px; }
      .anatomy-inner, .dev-inner, .chaos-inner-wrap { padding: 0 28px; }
      .anatomy-outer, .dev-section, .chaos-outer { padding: 80px 0; }
      .anatomy-parts { grid-template-columns: 1fr 1fr; }
      .types-grid { grid-template-columns: 1fr; }
      .stages-row { grid-template-columns: 1fr 1fr; }
      .stats-grid { grid-template-columns: 1fr; }
      .incub-grid, .chaos-grid { grid-template-columns: 1fr; }
      .chaos-connection { padding: 32px 24px; }
      footer { flex-direction: column; gap: 12px; text-align: center; padding: 36px 28px; }
    }
  </style>
</head>
